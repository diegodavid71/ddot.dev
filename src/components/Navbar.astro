---
import Section from './Section.astro';
---

<header
	class="sticky top-0 z-50 border-b border-stone-200 bg-stone-50/80 backdrop-blur-sm dark:border-stone-800 dark:bg-stone-950/80"
>
	<Section>
		<div class="flex h-14 items-center justify-between">
			<a href="/" class="text-sm font-bold text-stone-900 dark:text-stone-100">
				ddot.dev
			</a>
			<nav class="hidden items-center gap-6 text-xs text-stone-500 dark:text-stone-400 sm:flex">
				<a href="#about" class="transition-colors hover:text-stone-900 dark:hover:text-stone-100"
					>about</a
				>
				<a href="#experience" class="transition-colors hover:text-stone-900 dark:hover:text-stone-100"
					>work</a
				>
				<a href="#projects" class="transition-colors hover:text-stone-900 dark:hover:text-stone-100"
					>projects</a
				>
				<a href="#skills" class="transition-colors hover:text-stone-900 dark:hover:text-stone-100"
					>skills</a
				>
				<a href="#contact" class="transition-colors hover:text-stone-900 dark:hover:text-stone-100"
					>contact</a
				>
			</nav>
			<div class="flex items-center">
				<input type="checkbox" id="light-switch" class="light-switch sr-only" />
				<label
					class="cursor-pointer p-2 text-stone-500 transition-colors hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100"
					for="light-switch"
				>
					<svg class="dark:hidden" width="16" height="16" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
						<path
							class="fill-current"
							d="M7 0h2v2H7zM12.88 1.637l1.414 1.415-1.415 1.413-1.413-1.414zM14 7h2v2h-2zM12.95 14.433l-1.414-1.413 1.413-1.415 1.415 1.414zM7 14h2v2H7zM2.98 14.364l-1.413-1.415 1.414-1.414 1.414 1.415zM0 7h2v2H0zM3.05 1.706 4.463 3.12 3.05 4.535 1.636 3.12z"
						></path>
						<path
							class="fill-current"
							d="M8 4C5.8 4 4 5.8 4 8s1.8 4 4 4 4-1.8 4-4-1.8-4-4-4Z"
						></path>
					</svg>
					<svg class="hidden dark:block" width="16" height="16" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
						<path
							class="fill-current"
							d="M6.2 1C3.2 1.8 1 4.6 1 7.9 1 11.8 4.2 15 8.1 15c3.3 0 6-2.2 6.9-5.2C9.7 11.2 4.8 6.3 6.2 1Z"
						></path>
						<path
							class="fill-current"
							d="M12.5 5a.625.625 0 0 1-.625-.625 1.252 1.252 0 0 0-1.25-1.25.625.625 0 1 1 0-1.25 1.252 1.252 0 0 0 1.25-1.25.625.625 0 1 1 1.25 0c.001.69.56 1.249 1.25 1.25a.625.625 0 1 1 0 1.25c-.69.001-1.249.56-1.25 1.25A.625.625 0 0 1 12.5 5Z"
						></path>
					</svg>
					<span class="sr-only">Switch to light / dark version</span>
				</label>
			</div>
		</div>
	</Section>
</header>

<script>
	function applyTheme(isDark: boolean) {
		if (isDark) {
			document.documentElement.classList.add('dark');
			localStorage.setItem('theme', 'dark');
		} else {
			document.documentElement.classList.remove('dark');
			localStorage.setItem('theme', 'light');
		}
	}

	function initThemeToggle() {
		const lightSwitches = document.querySelectorAll('.light-switch');
		lightSwitches.forEach((lightSwitch) => {
			(lightSwitch as HTMLInputElement).checked =
				document.documentElement.classList.contains('dark');
			lightSwitch.addEventListener('click', () => {
				applyTheme((lightSwitch as HTMLInputElement).checked);
			});
		});
	}

	document.addEventListener('astro:page-load', initThemeToggle);
</script>
