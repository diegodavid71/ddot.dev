---
import Section from './Section.astro';
import { AppConfig } from '@/utils/AppConfig';
---

<Section id="contact">
	<div class="border-t border-stone-200 py-16 dark:border-stone-800 md:py-24">
		<p class="mb-8 text-xs uppercase tracking-widest text-stone-400 dark:text-stone-500">
			05. contact
		</p>
		<p class="mb-6 text-sm leading-7 text-stone-600 dark:text-stone-400">
			Open to new opportunities. If you want to discuss a role, a project, or just say hello —
			reach out.
		</p>
		<div class="flex flex-wrap gap-x-8 gap-y-2 text-sm">
			<a
				href={`mailto:${AppConfig.email}`}
				class="text-stone-900 underline underline-offset-4 transition-colors hover:text-orange-600 dark:text-stone-100 dark:hover:text-orange-500"
			>
				{AppConfig.email}
			</a>
			<a
				href={AppConfig.github}
				target="_blank"
				rel="noopener noreferrer"
				class="text-stone-400 underline underline-offset-4 transition-colors hover:text-stone-900 dark:text-stone-500 dark:hover:text-stone-100"
			>
				github
			</a>
			<a
				href={AppConfig.linkedin}
				target="_blank"
				rel="noopener noreferrer"
				class="text-stone-400 underline underline-offset-4 transition-colors hover:text-stone-900 dark:text-stone-500 dark:hover:text-stone-100"
			>
				linkedin
			</a>
		</div>
	</div>
</Section>
