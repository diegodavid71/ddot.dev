---
import Section from './Section.astro';

interface Project {
	number: string;
	title: string;
	description: string;
	live: string | null;
	code: string | null;
	tags: string[];
}

const projects: Project[] = [
	{
		number: '01',
		title: 'Project title',
		description:
			'Describe the problem you solved, how you solved it, and the measurable impact. What did you build and why does it matter?',
		live: null,
		code: null,
		tags: ['Python', 'AWS Lambda', 'DynamoDB']
	},
	{
		number: '02',
		title: 'Project title',
		description:
			'Describe the problem you solved, how you solved it, and the measurable impact. What did you build and why does it matter?',
		live: null,
		code: null,
		tags: ['Python', 'FastAPI', 'PostgreSQL']
	},
	{
		number: '03',
		title: 'Project title',
		description:
			'Describe the problem you solved, how you solved it, and the measurable impact. What did you build and why does it matter?',
		live: null,
		code: null,
		tags: ['React', 'TypeScript', 'Tailwind']
	}
];
---

<Section id="projects">
	<div class="border-t border-stone-200 py-16 dark:border-stone-800 md:py-24">
		<p class="mb-8 text-xs uppercase tracking-widest text-stone-400 dark:text-stone-500">
			03. projects
		</p>
		<ul class="space-y-10">
			{
				projects.map((project) => (
					<li>
						<div class="flex items-baseline justify-between gap-4">
							<div class="flex items-baseline gap-3">
								<span class="text-xs text-stone-300 dark:text-stone-600">{project.number}</span>
								<h3 class="text-sm font-medium text-stone-900 dark:text-stone-100">
									{project.title}
								</h3>
							</div>
							<div class="flex shrink-0 gap-4 text-xs text-stone-400 dark:text-stone-500">
								{project.live && (
									<a
										href={project.live}
										target="_blank"
										rel="noopener noreferrer"
										class="transition-colors hover:text-orange-600 dark:hover:text-orange-500"
									>
										↗ live
									</a>
								)}
								{project.code && (
									<a
										href={project.code}
										target="_blank"
										rel="noopener noreferrer"
										class="transition-colors hover:text-orange-600 dark:hover:text-orange-500"
									>
										↗ code
									</a>
								)}
							</div>
						</div>
						<p class="mt-2 pl-7 text-sm leading-6 text-stone-600 dark:text-stone-400">
							{project.description}
						</p>
						<p class="mt-2 pl-7 text-xs text-stone-400 dark:text-stone-500">
							{project.tags.join(' · ')}
						</p>
					</li>
				))
			}
		</ul>
	</div>
</Section>
